{
  "name": "@eshop/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "nodemon:all": "concurrently -k -n api,auth,product \"npm run dev:api-gateway\" \"npm run dev:auth-service\" \"npm run dev:product-service\"",
    "prod:all": "concurrently -k -n api,auth,product \"npm run prod:api-gateway\" \"npm run prod:auth-service\" \"npm run prod:product-service\"",
    "dev:all": "npx nx run-many -t serve --all --configuration=development --parallel",
    "dev": "npx nx run-many -t serve --projects=@eshop/api-gateway,@eshop/auth-service --configuration=development",
    "dev:ui": "npx nx run-many -t dev --projects=@eshop/user-ui,@eshop/seller-ui",
    "user-ui": "npx nx run @eshop/user-ui:dev",
    "seller-ui": "npx nx run @eshop/seller-ui:dev",
    "user-ui-test": "npx nx run @eshop/user-ui:dev",
    "dev:development": "npx nx run-many -t serve --projects=@eshop/api-gateway,@eshop/auth-service --configuration=development",
    "build": "npx nx run-many --target=build --all --configuration=production",
    "serve:api-gateway": "nx serve @eshop/api-gateway --configuration=development",
    "serve:auth-service": "nx serve @eshop/auth-service --configuration=development",
    "serve:api-gateway:prod": "nx serve @eshop/api-gateway --configuration=production",
    "serve:auth-service:prod": "nx serve @eshop/auth-service --configuration=production",
    "build:api-gateway": "nx build @eshop/api-gateway --configuration=production",
    "build:auth-service": "nx build @eshop/auth-service --configuration=production",
    "prod:api-gateway": "npx nx run @eshop/api-gateway:build:production && node apps/api-gateway/dist/main.js",
    "prod:auth-service": "npx nx run @eshop/auth-service:build:production && node apps/auth-service/dist/main.js",
    "prod:product-service": "npx nx run @eshop/product-service:build:production && node apps/product-service/dist/main.js",
    "start:api-gateway": "node apps/api-gateway/dist/main.js",
    "start:auth-service": "node apps/auth-service/dist/main.js",
    "start:product-service": "node apps/product-service/dist/main.js",
    "prisma:generate": "npx prisma generate",
    "lint": "nx lint",
    "test": "nx test",
    "dev:api-gateway": "concurrently -k -n build,serve \"npx nx run @eshop/api-gateway:build:development --watch\" \"nodemon --watch apps/api-gateway/dist --delay 200ms --exec \\\"node apps/api-gateway/dist/main.js\\\"\"",
    "dev:auth-service": "concurrently -k -n build,serve \"npx nx run @eshop/auth-service:build:development --watch\" \"nodemon --watch apps/auth-service/dist --delay 200ms --exec \\\"node apps/auth-service/dist/main.js\\\"\"",
    "dev:product-service": "concurrently -k -n build,serve \"npx nx run @eshop/product-service:build:development --watch\" \"nodemon --watch apps/product-service/dist --delay 200ms --exec \\\"node apps/product-service/dist/main.js\\\"\""
  },
  "private": true,
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4.1.13",
    "@tanstack/react-query": "^5.85.3",
    "@upstash/redis": "^1.35.3",
    "axios": "^1.11.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-http-proxy": "^2.1.1",
    "express-rate-limit": "^8.0.1",
    "jotai": "^2.15.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.539.0",
    "morgan": "^1.10.1",
    "next": "~15.2.4",
    "nodemailer": "^7.0.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.62.0",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-quill-new": "^3.8.3",
    "stripe": "^18.5.0"
  },
  "devDependencies": {
    "@juristr/nx-tailwind-sync": "^0.0.9",
    "@nx/esbuild": "21.3.11",
    "@nx/express": "21.6.10",
    "@nx/jest": "21.3.11",
    "@nx/js": "21.6.10",
    "@nx/next": "^21.3.11",
    "@nx/node": "21.6.10",
    "@nx/web": "21.3.11",
    "@nx/webpack": "21.6.10",
    "@nx/workspace": "21.3.11",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "^1.15.33",
    "@swc/helpers": "~0.5.11",
    "@swc/jest": "~0.2.38",
    "@tanstack/react-query-devtools": "^5.85.9",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "^4.17.23",
    "@types/express-http-proxy": "^1.6.7",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "10.4.13",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "esbuild": "^0.19.2",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "nodemon": "^3.1.14",
    "nx": "21.3.11",
    "postcss": "^8.5.6",
    "prisma": "^6.19.3",
    "react-refresh": "^0.10.0",
    "tailwindcss": "^4.1.13",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.8.2",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
